/**music-rhythm.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #121212;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 120rpx;
}

.container {
  padding: 32rpx;
}

.logo-container {
  display: flex;
  align-items: center;
  padding-left: 32rpx;
}

.logo-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFD100;
}

.help-btn {
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 麦克风图标区域 */
.microphone-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 64rpx 0;
  margin-bottom: 32rpx;
}

.microphone-icon {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.microphone-icon.listening {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.8;
  }
}

/* 音频波纹效果 */
.audio-waves {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 400rpx;
}

.wave {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 4rpx solid #FFD100;
  border-radius: 50%;
  opacity: 0;
}

.wave1 {
  width: 200rpx;
  height: 200rpx;
  animation: wave-animation 2s infinite;
}

.wave2 {
  width: 300rpx;
  height: 300rpx;
  animation: wave-animation 2s infinite 0.5s;
}

.wave3 {
  width: 400rpx;
  height: 400rpx;
  animation: wave-animation 2s infinite 1s;
}

@keyframes wave-animation {
  0% {
    transform: translate(-50%, -50%) scale(0.5);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.5);
    opacity: 0;
  }
}

/* 灵敏度调节区 */
.sensitivity-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #E0E0E0;
  margin-bottom: 24rpx;
}

.slider-container {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.slider-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #1E1E1E;
  border: 2rpx solid #333333;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #E0E0E0;
  font-size: 40rpx;
  font-weight: bold;
}

.slider-btn:active {
  background-color: #333333;
}

.slider-wrapper {
  flex: 1;
  margin: 0 24rpx;
}

.sensitivity-value {
  text-align: center;
  font-size: 24rpx;
  color: #9E9E9E;
  margin-bottom: 16rpx;
}

.sensitivity-tips {
  display: flex;
  justify-content: space-between;
  padding: 0 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #9E9E9E;
}

/* 状态提示区 */
.status-section {
  margin-top: 32rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-item:last-child {
  margin-bottom: 0;
}

.status-label {
  font-size: 28rpx;
  color: #E0E0E0;
}

.status-value {
  font-size: 28rpx;
  color: #9E9E9E;
}

.status-value.active {
  color: #4CAF50;
}

.audio-level-bar {
  width: 200rpx;
  height: 8rpx;
  background-color: #333333;
  border-radius: 4rpx;
  overflow: hidden;
}

.audio-level-fill {
  height: 100%;
  background-color: #FFD100;
  border-radius: 4rpx;
  transition: width 0.1s;
}
