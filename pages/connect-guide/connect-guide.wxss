/** connect-guide.wxss **/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #121212;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 48rpx;
}

.container {
  padding: 32rpx 40rpx 48rpx;
  box-sizing: border-box;
}

.logo-container {
  display: flex;
  align-items: center;
  padding-left: 32rpx;
}

.logo-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFD100;
}

.step-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.step-row--notes {
  margin-bottom: 0;
}

.step-num {
  flex-shrink: 0;
  width: 88rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.1;
}

.step-body {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.step-desc {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #E0E0E0;
  line-height: 1.55;
}

/* 用 view 代替 button，避免系统按钮默认整行居中、宽度撑满 */
.step-body--with-connect {
  align-items: flex-start;
}

.connect-btn {
  margin-top: 28rpx;
  margin-bottom: 20rpx;
  width: 200rpx;
  height: 80rpx;
  padding: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #121212;
  background-color: #FFD100;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.connect-btn-hover {
  opacity: 0.88;
}

.step-sub {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #9E9E9E;
  line-height: 1.5;
}

.notes-title {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #E0E0E0;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.notes-text {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #9E9E9E;
  line-height: 1.6;
}
