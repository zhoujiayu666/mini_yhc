<!--pages/settings/settings.wxml-->
<navigation-bar title="" back="{{true}}" color="#E0E0E0" background="#121212">
  <view slot="left" class="logo-container">
    <view class="logo-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="3" fill="#FFD100"/>
        <path d="M12 2V6M12 18V22M2 12H6M18 12H22M4.93 4.93L7.76 7.76M16.24 16.24L19.07 19.07M4.93 19.07L7.76 16.24M16.24 7.76L19.07 4.93" stroke="#FFD100" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </view>
    <text class="logo-text">设置</text>
  </view>
</navigation-bar>

<scroll-view class="scrollarea" scroll-y>
  <view class="container">
    <!-- 设备信息 -->
    <view class="settings-section card">
      <view class="section-title">设备信息</view>
      <view class="settings-item">
        <text class="settings-label">设备名称</text>
        <text class="settings-value">{{deviceName}}</text>
      </view>
      <view class="settings-item">
        <text class="settings-label">固件版本</text>
        <text class="settings-value">{{firmwareVersion}}</text>
      </view>
    </view>

    <!-- 连接设置 -->
    <view class="settings-section card">
      <view class="section-title">连接设置</view>
      <view class="settings-item">
        <text class="settings-label">自动连接</text>
        <switch checked="{{autoConnect}}" color="#FFD100" bindchange="toggleAutoConnect"/>
      </view>
    </view>

    <!-- 通知设置 -->
    <view class="settings-section card">
      <view class="section-title">通知设置</view>
      <view class="settings-item">
        <text class="settings-label">消息通知</text>
        <switch checked="{{notifications}}" color="#FFD100" bindchange="toggleNotifications"/>
      </view>
    </view>

    <!-- 其他设置 -->
    <view class="settings-section card">
      <view class="section-title">其他</view>
      <view class="settings-item clickable" bindtap="clearCache">
        <text class="settings-label">清除缓存</text>
        <text class="settings-arrow">></text>
      </view>
      <view class="settings-item clickable" bindtap="showAbout">
        <text class="settings-label">关于</text>
        <text class="settings-arrow">></text>
      </view>
    </view>
  </view>
</scroll-view>

<bottom-nav current="settings"></bottom-nav>
