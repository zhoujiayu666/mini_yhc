/**settings.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #121212;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 120rpx;
}

.container {
  padding: 32rpx;
}

.logo-container {
  display: flex;
  align-items: center;
  padding-left: 32rpx;
}

.logo-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFD100;
}

/* 设置区域 */
.settings-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #E0E0E0;
  margin-bottom: 24rpx;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #333333;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item.clickable {
  cursor: pointer;
}

.settings-item.clickable:active {
  opacity: 0.7;
}

.settings-label {
  font-size: 28rpx;
  color: #E0E0E0;
}

.settings-value {
  font-size: 28rpx;
  color: #9E9E9E;
}

.settings-arrow {
  font-size: 32rpx;
  color: #9E9E9E;
}
