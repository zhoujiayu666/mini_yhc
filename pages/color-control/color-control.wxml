<!--pages/color-control/color-control.wxml-->
<navigation-bar title="" back="{{true}}" color="#E0E0E0" background="#121212">
  <view slot="left" class="logo-container">
    <view class="logo-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="3" fill="#FFD100"/>
        <path d="M12 2V6M12 18V22M2 12H6M18 12H22M4.93 4.93L7.76 7.76M16.24 16.24L19.07 19.07M4.93 19.07L7.76 16.24M16.24 7.76L19.07 4.93" stroke="#FFD100" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </view>
    <text class="logo-text">智能调光</text>
  </view>
  <view slot="right" class="help-btn" bindtap="showHelp">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="10" stroke="#9E9E9E" stroke-width="2"/>
      <path d="M9 9C9 7.34315 10.3431 6 12 6C13.6569 6 15 7.34315 15 9C15 10.6569 13.6569 12 12 12V14" stroke="#9E9E9E" stroke-width="2" stroke-linecap="round"/>
      <circle cx="12" cy="18" r="1" fill="#9E9E9E"/>
    </svg>
  </view>
</navigation-bar>

<scroll-view class="scrollarea" scroll-y>
  <view class="container">
    <!-- 色轮区域 -->
    <view class="color-wheel-section">
      <color-wheel 
        hue="{{hue}}"
        saturation="{{saturation}}"
        brightness="{{brightness}}"
        bindchange="onColorChange"
      ></color-wheel>
    </view>

    <!-- 亮度调节区 -->
    <view class="brightness-section card">
      <view class="section-title">亮度调节</view>
      <view class="slider-container">
        <view class="slider-btn" bindtap="decreaseBrightness">−</view>
        <view class="slider-wrapper">
          <view class="slider-track-shell">
            <slider
              class="track-slider"
              value="{{brightness}}"
              min="0"
              max="100"
              step="1"
              activeColor="#FFD100"
              backgroundColor="#3D3D3D"
              block-color="#FFD100"
              block-size="28"
              bindchange="onBrightnessChange"
            />
          </view>
        </view>
        <view class="slider-btn" bindtap="increaseBrightness">+</view>
      </view>
      <view class="brightness-value">亮度 {{brightness}}%</view>
    </view>

    <!-- 预设效果区 -->
    <view class="preset-section">
      <view class="section-title">预设效果</view>
      <view class="preset-grid">
        <view 
          class="preset-item {{selectedEffect === item.id ? 'active' : ''}}"
          wx:for="{{presetEffects}}"
          wx:key="id"
          data-effect="{{item}}"
          bindtap="selectEffect"
        >
          <view class="preset-icon">{{item.icon}}</view>
          <text class="preset-name">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<bottom-nav current="settings"></bottom-nav>
