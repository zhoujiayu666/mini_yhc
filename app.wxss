/**app.wxss**/
/* 全局样式变量 */
page {
  --brand-yellow: #FFD100;
  --bg-black: #121212;
  --text-primary: #E0E0E0;
  --text-secondary: #9E9E9E;
  --success-green: #4CAF50;
  --warning-orange: #FF9800;
  --error-red: #F44336;
  --card-bg: #1E1E1E;
  --border-color: #333333;
  
  background-color: var(--bg-black);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 通用容器：不设 min-height，避免内容不足一屏时仍可拉出大片空白；
   底部留白与 bottom-nav（88rpx + 安全区）对齐，避免最后一项被挡住 */
.container {
  padding-bottom: calc(88rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background-color: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 16rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

/* 通用按钮样式 */
.btn {
  background-color: var(--card-bg);
  color: var(--text-primary);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  text-align: center;
  border: 2rpx solid var(--border-color);
  transition: all 0.3s;
}

.btn-active {
  background-color: var(--brand-yellow);
  color: var(--bg-black);
  border-color: var(--brand-yellow);
}

/* 通用滑块样式 */
.slider-container {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.slider-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: var(--card-bg);
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-primary);
  font-size: 40rpx;
  font-weight: bold;
}

.slider-wrapper {
  flex: 1;
  margin: 0 24rpx;
}
